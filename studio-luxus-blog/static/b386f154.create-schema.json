[
  {
    "fields": [
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "name": "title",
        "type": "string",
        "title": "Título"
      },
      {
        "options": {
          "source": "title",
          "maxLength": 96
        },
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "custom"
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "name": "slug",
        "type": "slug"
      },
      {
        "options": {
          "hotspot": true
        },
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "fields": [
          {
            "name": "alt",
            "type": "string",
            "title": "Texto Alternativo"
          }
        ],
        "name": "mainImage",
        "type": "image",
        "title": "Imagen de portada"
      },
      {
        "of": [
          {
            "to": [
              {
                "type": "category"
              }
            ],
            "type": "reference",
            "title": "Reference to categoría"
          }
        ],
        "name": "categories",
        "type": "array",
        "title": "Categorías"
      },
      {
        "name": "publishedAt",
        "type": "datetime",
        "title": "Fecha de publicación"
      },
      {
        "rows": 3,
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "max",
                "constraint": 200
              }
            ]
          }
        ],
        "description": "Aparece en las tarjetas del blog. Máximo 200 caracteres recomendado.",
        "name": "excerpt",
        "type": "text",
        "title": "Resumen (Excerpt)"
      },
      {
        "of": [
          {
            "lists": [
              {
                "value": "bullet",
                "title": "Bulleted list"
              },
              {
                "value": "number",
                "title": "Numbered list"
              }
            ],
            "marks": {
              "annotations": [
                {
                  "i18nTitleKey": "inputs.portable-text.annotation.link",
                  "options": {
                    "modal": {
                      "type": "popover"
                    }
                  },
                  "fields": [
                    {
                      "validation": [
                        {
                          "level": "error",
                          "rules": [
                            {
                              "flag": "uri",
                              "constraint": {
                                "options": {
                                  "scheme": [
                                    "/^http$/",
                                    "/^https$/",
                                    "/^tel$/",
                                    "/^mailto$/"
                                  ],
                                  "allowRelative": true,
                                  "relativeOnly": false,
                                  "allowCredentials": false
                                }
                              }
                            }
                          ]
                        }
                      ],
                      "description": "A valid web, email, phone, or relative link.",
                      "name": "href",
                      "type": "url",
                      "title": "Link"
                    }
                  ],
                  "name": "link",
                  "type": "object"
                }
              ],
              "decorators": [
                {
                  "value": "strong",
                  "title": "Strong"
                },
                {
                  "value": "em",
                  "title": "Italic"
                },
                {
                  "value": "code",
                  "title": "Code"
                },
                {
                  "value": "underline",
                  "title": "Underline"
                },
                {
                  "value": "strike-through",
                  "title": "Strike"
                }
              ]
            },
            "of": [],
            "styles": [
              {
                "value": "normal",
                "title": "Normal"
              },
              {
                "value": "h2",
                "title": "H2"
              },
              {
                "value": "h3",
                "title": "H3"
              },
              {
                "value": "blockquote",
                "title": "Cita"
              }
            ],
            "type": "block"
          },
          {
            "options": {
              "hotspot": true
            },
            "type": "image"
          }
        ],
        "name": "content",
        "type": "array",
        "title": "Cuerpo del artículo"
      }
    ],
    "name": "post",
    "type": "document",
    "title": "Publicación del Blog"
  },
  {
    "fields": [
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ],
            "message": "El título es obligatorio para el filtrado."
          }
        ],
        "description": "Ejemplo: Comunicación Institucional, Gestión de Crisis, etc.",
        "name": "title",
        "type": "string",
        "title": "Título"
      },
      {
        "name": "description",
        "type": "text",
        "title": "Descripción"
      }
    ],
    "name": "category",
    "type": "document",
    "title": "Categoría"
  }
]