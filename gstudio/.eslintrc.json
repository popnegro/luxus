{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off"
  },
  "overrides": [
    {
      "files": ["assets/js/**/*.js"],
      "env": {
        "browser": true,
        "node": false
      },
      "globals": {
        "DOMPurify": "readonly",
        "dataLayer": "writable",
        "gtag": "writable"
      }
    }
  ]
}